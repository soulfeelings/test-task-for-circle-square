{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": ["DOM", "ES2020"],
    "jsx": "react-jsx"
  },
  "include": ["src"],
  "exclude": ["dist"]
}
